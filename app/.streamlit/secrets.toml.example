# 로컬: 이 파일을 secrets.toml로 복사하고 값을 채우세요 (secrets.toml은 git에 올리지 않음)
# 배포: Streamlit Community Cloud > App settings > Secrets 에 동일 내용을 붙여넣기

[database]
# Supabase Settings > Database > Connection string > URI (psycopg3 방언 사용)
# 예: postgresql+psycopg://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
url = "postgresql+psycopg://USER:PASSWORD@HOST:PORT/postgres"

[app]
# 재고 현황 경고 임계값
low_stock_days_threshold = 14
near_expiry_ratio_threshold = 0.3

[planning]
# 입고 계산 엔진 파라미터
lead_time_days = 7           # 주문 → FC 입고까지 (일)
target_cover_days = 14       # 도착 시점 확보할 판매 가능 일수 (주1회 운영 기준)
velocity_alpha = 0.4         # 7일 판매평균 가중치 (0~1, 나머지는 30일 평균)
overstock_days = 35          # 이 일수 초과 시 과잉재고 경고
reproduction_lead_days = 28  # 제품 재생산 리드타임 — 재발주 알림 기준

# 중기(API 자동수집) — 단계 2 이후에 채움
